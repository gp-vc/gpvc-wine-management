rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function getEmail() {
      return request.auth.token.email.lower();
    }

    function isGpVcUser() {
      return isSignedIn() && 
             'email' in request.auth.token &&
             getEmail().endsWith('@gp-vc.com');
    }

    // Access check: User owns it, or it's a shared GP-VC document and user is from GP-VC
    function canAccess(ownerId) {
      return isSignedIn() && (
        request.auth.uid == ownerId ||
        getEmail() == ownerId ||
        (ownerId == 'gp-vc.com' && isGpVcUser()) ||
        (isGpVcUser() && (getEmail() == 'kwlee@gp-vc.com' || getEmail() == 'lee@gp-vc.com'))
      );
    }

    // Collections - Simplified for domain users
    match /wines/{id} {
      allow read, list: if isGpVcUser() || canAccess(resource.data.ownerId);
      allow create: if isGpVcUser();
      allow update, delete: if isGpVcUser();
    }

    match /partners/{id} {
      allow read, list: if isGpVcUser() || canAccess(resource.data.ownerId);
      allow create: if isGpVcUser();
      allow update, delete: if isGpVcUser();
    }

    match /transactions/{id} {
      allow read, list: if isGpVcUser() || canAccess(resource.data.ownerId);
      allow create: if isGpVcUser() && 
                      (!('createdByEmail' in request.resource.data) || request.resource.data.createdByEmail == getEmail());
      allow update, delete: if isGpVcUser();
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
