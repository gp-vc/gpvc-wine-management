rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: wines
    // Fields: name, producer, region, country, type, vintage, quantity, price, location, status, importDate, ownerId
    //
    // Collection: partners
    // Fields: name, type, contact, email, location, ownerId
    //
    // Collection: transactions
    // Fields: wineId, wineName, partnerId, partnerName, type, quantity, date, ownerId
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(ownerId) {
      return isAuthenticated() && (
        request.auth.uid == ownerId ||
        (request.auth.token.email_verified == true && request.auth.token.email.hasSuffix('@' + ownerId))
      );
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // Domain Validators
    function isValidWine(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.quantity is number && data.quantity >= 0 &&
             data.ownerId == request.auth.uid;
    }

    function isValidPartner(data) {
      return data.name is string && data.name.size() > 0 &&
             data.type in ['Supplier', 'Client'] &&
             data.ownerId == request.auth.uid;
    }

    function isValidTransaction(data) {
      return data.type in ['Inbound', 'Outbound'] &&
             data.quantity is number && data.quantity > 0 &&
             data.ownerId == request.auth.uid;
    }

    // Rules
    match /wines/{wineId} {
      allow read: if isOwner(resource.data.ownerId);
      allow create: if isAuthenticated() && isValidWine(request.resource.data);
      allow update: if isOwner(resource.data.ownerId) && isValidWine(request.resource.data);
      allow delete: if isOwner(resource.data.ownerId);
    }

    match /partners/{partnerId} {
      allow read: if isOwner(resource.data.ownerId);
      allow create: if isAuthenticated() && isValidPartner(request.resource.data);
      allow update: if isOwner(resource.data.ownerId) && isValidPartner(request.resource.data);
      allow delete: if isOwner(resource.data.ownerId);
    }

    match /transactions/{transactionId} {
      allow read: if isOwner(resource.data.ownerId);
      allow create: if isAuthenticated() && isValidTransaction(request.resource.data);
      allow update: if isOwner(resource.data.ownerId) && isValidTransaction(request.resource.data);
      allow delete: if isOwner(resource.data.ownerId);
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
